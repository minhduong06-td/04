APP_ENV=development
HTTP_ADDR=:8080
DATABASE_URL=postgres://hustack:hustack@postgres:5432/hustack?sslmode=disable
REDIS_ADDR=redis:6379
SOURCE_STORAGE_ROOT=/var/lib/hustack/sources
COOKIE_HMAC_SECRET=dev-secret-change-in-production-min-32-chars!!
PUBLIC_BASE_URL=http://localhost:8080
MAX_SOURCE_BYTES=10485760
REQUEST_BODY_LIMIT=11534336
QUEUE_MAX_DEPTH=500
SUBMIT_RATE_PER_MINUTE=6
SUBMIT_RATE_PER_HOUR=120
IP_SUBMIT_RATE_PER_MINUTE=20
POLL_RATE_PER_MINUTE=60
MAX_QUEUED_PER_PARTICIPANT=3
MAX_RUNNING_PER_PARTICIPANT=1
MOCK_WORK_DURATION=200ms
TRUSTED_PROXY_CIDR=172.0.0.0/8
